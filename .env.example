WG_PANEL_DOMAIN=vpn.example.com
# Optional. Used as fallback GeoIP when a registration comes from a private VPN/LAN IP.
WG_PANEL_PUBLIC_IP=
WG_PANEL_ADMIN_USER=admin
WG_PANEL_ADMIN_PASSWORD=change-this-before-first-start

WG_PANEL_BIND_HOST=127.0.0.1
WG_PANEL_PORT=8080
WG_PANEL_ENABLE_INTERNAL_TLS=0
WG_PANEL_ENABLE_HTTP_REDIRECT=0
WG_PANEL_REDIRECT_SOCKET_TIMEOUT=5
WG_PANEL_TRUST_PROXY=1

WG_PANEL_WG_DIR=/etc/wireguard
WG_PANEL_DATA_DIR=/opt/wg-panel/data

# Optional. Leave empty to disable Telegram notifications/webhook.
WG_PANEL_TELEGRAM_BOT_TOKEN=
WG_PANEL_TELEGRAM_CHAT_ID=
